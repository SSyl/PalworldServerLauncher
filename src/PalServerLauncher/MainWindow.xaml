<Window x:Class="PalServerLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PalServerLauncher"
        xmlns:vm="clr-namespace:PalServerLauncher.ViewModels"
        xmlns:loc="clr-namespace:PalServerLauncher.Localization;assembly=PalServerLauncher.Localization"
        mc:Ignorable="d"
        Title="{x:Static loc:Strings.Common_AppName}" Height="656" Width="1000"
        Icon="logo.png"
        Background="{x:Static local:Theme.Window}" Foreground="{x:Static local:Theme.Text}"
        FontFamily="Segoe UI" FontSize="13"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <!-- Reuses the app-wide Button style (App.xaml, Theme-driven fill/border/hover), only adding the row
             gap. No duplicate template: change the button look in App.xaml and it applies here too. -->
        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="Caption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{x:Static local:Theme.TextCaption}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="Value" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{x:Static local:Theme.Text}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- BasedOn the app-wide CheckBox style so the IsEnabled=False -> Opacity 0.4 dimming trigger carries
             over (a plain local style would replace it and leave disabled boxes looking active). -->
        <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Dim a non-checkbox row (e.g. the update-interval field row) to match when it's disabled. -->
        <Style x:Key="DimWhenDisabled" TargetType="StackPanel">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Titled grouping box -->
        <Style x:Key="Box" TargetType="Border">
            <Setter Property="BorderBrush" Value="{x:Static local:Theme.Divider}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
        <Style x:Key="BoxHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{x:Static local:Theme.Text}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- action buttons -->
            <RowDefinition Height="Auto"/>   <!-- status / update + public IP -->
            <RowDefinition Height="Auto"/>   <!-- settings sections (collapsible) -->
            <RowDefinition Height="*"/>      <!-- log tabs -->
            <RowDefinition Height="Auto"/>   <!-- bottom stats bar -->
        </Grid.RowDefinitions>

        <!-- Row 0: action buttons (left) + settings dialogs (right) -->
        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,10">
            <Button DockPanel.Dock="Left" Content="{Binding PrimaryActionText}" Command="{Binding PrimaryActionCommand}" MinWidth="46" FontSize="16" FontWeight="SemiBold"
                    ToolTip="{x:Static loc:Strings.Main_PrimaryTip}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Style.Triggers>
                            <!-- Color the button by what it does: Install/Start green, Stop red. Busy tints blue
                                 and is listed last so it wins (PrimaryActionKind is None while busy anyway). -->
                            <DataTrigger Binding="{Binding PrimaryActionKind}" Value="Install">
                                <Setter Property="Background" Value="{x:Static local:Theme.Start}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding PrimaryActionKind}" Value="Start">
                                <Setter Property="Background" Value="{x:Static local:Theme.Start}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding PrimaryActionKind}" Value="Stop">
                                <Setter Property="Background" Value="{x:Static local:Theme.Danger}"/>
                            </DataTrigger>
                            <!-- Amber while a timed shutdown counts down: the button becomes a clickable "shut down now". -->
                            <DataTrigger Binding="{Binding PrimaryActionKind}" Value="ShutdownNow">
                                <Setter Property="Background" Value="{x:Static local:Theme.Countdown}"/>
                            </DataTrigger>
                            <!-- Fixed width while a transitional label animates its dots (Starting/Stopping/
                                 Restarting), same idea as the busy state, so the button doesn't resize. -->
                            <DataTrigger Binding="{Binding IsTransitionalAnimating}" Value="True">
                                <Setter Property="Width" Value="124"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="Background" Value="{x:Static local:Theme.Accent}"/>
                                <Setter Property="Opacity" Value="1"/>
                                <!-- Fixed width while busy so the animated "Working..." dots don't resize the button. -->
                                <Setter Property="Width" Value="108"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button DockPanel.Dock="Left" Content="{x:Static loc:Strings.Main_ImportServer}" Click="OnImportServer"
                    IsEnabled="{Binding CanImport}" Visibility="{Binding ImportVisible, Converter={StaticResource BoolToVis}}"
                    ToolTip="{x:Static loc:Strings.Main_ImportServerTip}"/>
            <Button DockPanel.Dock="Left" Content="↻" Command="{Binding RestartCommand}" FontSize="16" MinWidth="40"
                    ToolTip="{x:Static loc:Strings.Main_RestartTip}"/>
            <Button DockPanel.Dock="Left" Content="{x:Static loc:Strings.Common_ForceShutdown}" Click="OnForceShutdown"
                    Visibility="{Binding IsForceShutdownVisible, Converter={StaticResource BoolToVis}}"
                    ToolTip="{x:Static loc:Strings.Main_ForceShutdownTip}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Background" Value="{x:Static local:Theme.Danger}"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{x:Static local:Theme.DangerHover}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button DockPanel.Dock="Left" Content="{x:Static loc:Strings.Main_CheckForUpdate}" Click="OnCheckForUpdate" IsEnabled="{Binding CanCheckForUpdate}"
                    ToolTip="{x:Static loc:Strings.Main_CheckForUpdateTip}"/>
            <Button DockPanel.Dock="Left" Content="{x:Static loc:Strings.Main_ValidateFiles}" Command="{Binding ValidateFilesCommand}"
                    ToolTip="{x:Static loc:Strings.Main_ValidateFilesTip}"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="{x:Static loc:Strings.Main_ServerSettings}" Click="OnOpenServerSettings"
                        ToolTip="{x:Static loc:Strings.Main_ServerSettingsTip}"/>
                <Button Content="{x:Static loc:Strings.Main_Mods}" Click="OnOpenMods"
                        ToolTip="{x:Static loc:Strings.Main_ModsTip}"/>
                <Button Content="{x:Static loc:Strings.Main_DiscordBot}" Click="OnOpenDiscord" ToolTip="{x:Static loc:Strings.Main_DiscordBotTip}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Background" Value="{x:Static local:Theme.Discord}"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{x:Static local:Theme.DiscordHover}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button FontFamily="Segoe MDL2 Assets" Content="&#xE713;" FontSize="15" Padding="10,7" MinWidth="0" Margin="0" Click="OnOpenLauncherSettings"
                        ToolTip="{x:Static loc:Strings.LauncherSettings_Tooltip}"/>
            </StackPanel>
        </DockPanel>

        <!-- Row 1: status + update (left), public IP + port check (right) -->
        <DockPanel Grid.Row="1" LastChildFill="False" Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{x:Static loc:Strings.Main_StatusLabel}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding StateText}" Style="{StaticResource Value}" FontSize="15" VerticalAlignment="Center" Margin="0,0,24,0"/>
                <TextBlock Text="{x:Static loc:Strings.Main_UpdateLabel}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding UpdateStatus}" Foreground="{x:Static local:Theme.Text}" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{x:Static loc:Strings.Main_PublicIpLabel}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Border Background="{x:Static local:Theme.Field}" BorderBrush="{x:Static local:Theme.FieldBorder}" BorderThickness="1"
                        Width="185" VerticalAlignment="Center" Margin="0,0,4,0">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Click="OnToggleIpReveal" FontFamily="Segoe MDL2 Assets" Content="&#xE7B3;"
                                Background="Transparent" BorderThickness="0" MinWidth="0" Margin="0" Padding="9,0" FontSize="13"
                                VerticalAlignment="Stretch" ToolTip="{x:Static loc:Strings.Main_RevealIpTip}"/>
                        <TextBox Text="{Binding PublicIpDisplay, Mode=OneWay}" IsReadOnly="True" Background="Transparent"
                                 BorderThickness="0" VerticalContentAlignment="Center" ToolTip="{x:Static loc:Strings.Main_PublicIpTip}"/>
                    </DockPanel>
                </Border>
                <Button Click="OnCopyConnectionInfo" FontFamily="Segoe MDL2 Assets" Content="&#xE8C8;" Padding="9,5" MinWidth="0" IsEnabled="{Binding CanCopyConnectionInfo}"
                        ToolTip="{x:Static loc:Strings.Main_CopyIpTip}"/>
                <Button Content="{x:Static loc:Strings.Main_PortCheck}" Click="OnCheckPorts" IsEnabled="{Binding CanCheckPorts}" ToolTipService.ShowOnDisabled="True" Margin="8,0,0,0"
                        ToolTip="{x:Static loc:Strings.Main_PortCheckTip}"/>
            </StackPanel>
        </DockPanel>

        <!-- Bottom status bar: live server stats, under the log terminal -->
        <Border Grid.Row="4" BorderBrush="{x:Static local:Theme.Divider}" BorderThickness="0,1,0,0" Padding="0,7,0,0" Margin="0,8,0,0">
        <StackPanel Orientation="Horizontal">
            <StackPanel Orientation="Horizontal" Margin="0,0,20,0"><TextBlock Text="{x:Static loc:Strings.Main_StatVersion}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="{Binding Version}" Style="{StaticResource Value}" VerticalAlignment="Center"/></StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,20,0"><TextBlock Text="{x:Static loc:Strings.Main_StatFps}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="{Binding Fps}" Style="{StaticResource Value}" VerticalAlignment="Center"/></StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,20,0"><TextBlock Text="{x:Static loc:Strings.Main_StatCpu}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="{Binding Cpu}" Style="{StaticResource Value}" VerticalAlignment="Center"/></StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,20,0"><TextBlock Text="{x:Static loc:Strings.Main_StatMemory}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="{Binding Memory}" Style="{StaticResource Value}" VerticalAlignment="Center"/></StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,20,0"><TextBlock Text="{x:Static loc:Strings.Main_StatPlayers}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="{Binding Players}" Style="{StaticResource Value}" VerticalAlignment="Center"/></StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,20,0"><TextBlock Text="{x:Static loc:Strings.Main_StatUptime}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="{Binding Uptime}" Style="{StaticResource Value}" VerticalAlignment="Center"/></StackPanel>
            <StackPanel Orientation="Horizontal"><TextBlock Text="{x:Static loc:Strings.Main_StatNextRestart}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="{Binding NextRestart}" Style="{StaticResource Value}" VerticalAlignment="Center"/></StackPanel>
        </StackPanel>
        </Border>

        <!-- Settings sections (Restarts / Backups / Misc) with a collapse bar; hidden in Compact mode -->
        <StackPanel Grid.Row="2" Margin="0,0,0,14">
            <DockPanel Margin="0,0,0,8">
                <ToggleButton DockPanel.Dock="Left" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding CompactMode}"
                              VerticalAlignment="Center" Margin="2,0,8,0" ToolTip="{x:Static loc:Strings.Main_CollapseTip}"/>
                <TextBlock DockPanel.Dock="Left" Text="{x:Static loc:Strings.Main_CompactMode}" Style="{StaticResource Caption}"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Border Height="1" Background="{x:Static local:Theme.Divider}" VerticalAlignment="Center"/>
            </DockPanel>
        <Grid Visibility="{Binding ShowConfigBoxes, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Box}">
                <StackPanel>
                    <TextBlock Text="{x:Static loc:Strings.Main_RestartsHeader}" Style="{StaticResource BoxHeader}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                        <CheckBox Content="{x:Static loc:Strings.Main_ScheduledRestartAt}" IsChecked="{Binding ScheduledRestartEnabled}"
                                  ToolTip="{x:Static loc:Strings.Main_ScheduledRestartTip}"/>
                        <Button Content="{Binding RestartTimesSummary}" Click="OnEditRestartTimes" MinWidth="120" Margin="8,0,0,0" HorizontalContentAlignment="Left" ToolTip="{x:Static loc:Strings.Main_ChooseRestartTimes}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                        <TextBlock Text="{x:Static loc:Strings.Main_MinUptime}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Text="{Binding MinUptimeHours}" Width="30" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Static loc:Strings.Main_HourSuffix}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                        <CheckBox Content="{x:Static loc:Strings.Main_AnnounceRestarts}" IsChecked="{Binding AnnounceRestartsEnabled}"
                                  ToolTip="{x:Static loc:Strings.Main_AnnounceRestartsTip}"/>
                        <TextBox Text="{Binding AnnounceLead1}" Width="28" MaxLength="3" VerticalAlignment="Center" Margin="6,0,0,0"
                                 PreviewTextInput="OnDigitsOnly" DataObject.Pasting="OnLeadPaste" ToolTip="{x:Static loc:Strings.Main_AnnounceLeadTip}"/>
                        <TextBox Text="{Binding AnnounceLead2}" Width="28" MaxLength="3" VerticalAlignment="Center" Margin="4,0,0,0"
                                 PreviewTextInput="OnDigitsOnly" DataObject.Pasting="OnLeadPaste" ToolTip="{x:Static loc:Strings.Main_AnnounceLeadTip}"/>
                        <TextBox Text="{Binding AnnounceLead3}" Width="28" MaxLength="3" VerticalAlignment="Center" Margin="4,0,0,0"
                                 PreviewTextInput="OnDigitsOnly" DataObject.Pasting="OnLeadPaste" ToolTip="{x:Static loc:Strings.Main_AnnounceLeadTip}"/>
                        <TextBlock Text="{x:Static loc:Strings.Main_MinuteSuffix}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                    <Button Content="{x:Static loc:Strings.Main_EditAnnouncements}" Click="OnEditAnnouncements" HorizontalAlignment="Left" Margin="0,0,0,7"
                            ToolTip="{x:Static loc:Strings.Main_EditAnnouncementsTip}"/>
                    <CheckBox Content="{x:Static loc:Strings.Main_ValidateOnRestart}" IsChecked="{Binding VerifyOnUpdate}" ToolTip="{x:Static loc:Strings.Main_ValidateOnRestartTip}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Box}">
                <StackPanel>
                    <TextBlock Text="{x:Static loc:Strings.Main_BackupsHeader}" Style="{StaticResource BoxHeader}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                        <TextBlock Text="{x:Static loc:Strings.Main_BackupOn}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <CheckBox Content="{x:Static loc:Strings.Main_BackupStartup}" IsChecked="{Binding BackupOnStartup}"
                                  ToolTip="{x:Static loc:Strings.Main_BackupStartupTip}"/>
                        <CheckBox Content="{x:Static loc:Strings.Main_BackupShutdown}" IsChecked="{Binding BackupOnShutdown}" Margin="12,0,0,0"
                                  ToolTip="{x:Static loc:Strings.Main_BackupShutdownTip}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                        <CheckBox Content="{x:Static loc:Strings.Main_BackupScheduled}" IsChecked="{Binding ScheduledBackupEnabled}"
                                  ToolTip="{x:Static loc:Strings.Main_BackupScheduledTip}"/>
                        <Button Content="{Binding BackupTimesSummary}" Click="OnEditBackupTimes" MinWidth="90" Margin="6,0,0,0" HorizontalContentAlignment="Left" ToolTip="{x:Static loc:Strings.Main_ChooseBackupTimes}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,7"
                                ToolTip="{x:Static loc:Strings.Main_BackupRetentionTip}">
                        <TextBlock Text="{x:Static loc:Strings.Main_KeepFor}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Text="{Binding BackupRetentionDays}" Width="38" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Static loc:Strings.Main_DaysSuffix}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,7"
                                ToolTip="{x:Static loc:Strings.Main_BackupFolderTip}">
                        <TextBlock Text="{x:Static loc:Strings.Main_BackupFolderLabel}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Text="{Binding BackupFolder}" Width="200" VerticalAlignment="Center"/>
                        <Button Content="{x:Static loc:Strings.Main_Browse}" Click="OnBrowseBackupFolder" Margin="6,0,0,0"
                                ToolTip="{x:Static loc:Strings.Main_BackupFolderBrowseTip}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{x:Static loc:Strings.Main_NextBackupLabel}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding NextBackup}" Foreground="{x:Static local:Theme.Text}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Button Content="{x:Static loc:Strings.Main_BackupNow}" Command="{Binding BackupNowCommand}" Margin="0"
                                ToolTip="{x:Static loc:Strings.Main_BackupNowTip}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Box}" Margin="0">
                <StackPanel>
                    <TextBlock Text="{x:Static loc:Strings.Main_MiscHeader}" Style="{StaticResource BoxHeader}"/>
                    <!-- Version pin (item 2a): freezes the build and grays the update options below. -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                        <CheckBox Content="{x:Static loc:Strings.Main_PinVersion}" IsChecked="{Binding VersionPinEnabled}"
                                  IsEnabled="{Binding CanTogglePin}" ToolTip="{x:Static loc:Strings.Main_PinVersionTip}"/>
                        <TextBlock Text="{Binding PinnedBuildDisplay}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                    <CheckBox Content="{x:Static loc:Strings.Main_AutomaticUpdates}" IsChecked="{Binding AutomaticUpdatesOn}"
                              IsEnabled="{Binding IsNotPinned}" Margin="0,0,0,7"
                              ToolTip="{x:Static loc:Strings.Main_AutomaticUpdatesTip}"/>
                    <CheckBox Content="{x:Static loc:Strings.Main_UpdateOnStart}" IsChecked="{Binding UpdateOnStart}" Margin="16,0,0,7"
                              IsEnabled="{Binding IsNotPinned}" ToolTip="{x:Static loc:Strings.Main_UpdateOnStartTip}"/>
                    <CheckBox Content="{x:Static loc:Strings.Main_AutoUpdate}" IsChecked="{Binding AutoUpdateEnabled}" Margin="16,0,0,7"
                              IsEnabled="{Binding IsNotPinned}" ToolTip="{x:Static loc:Strings.Main_AutoUpdateTip}"/>
                    <StackPanel Orientation="Horizontal" Margin="16,0,0,7" IsEnabled="{Binding AutoUpdateEnabled}" Style="{StaticResource DimWhenDisabled}">
                        <TextBlock Text="{x:Static loc:Strings.Main_CheckUpdateEvery}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Text="{Binding UpdateCheckMinutes}" Width="40" MaxLength="4" VerticalAlignment="Center"
                                 PreviewTextInput="OnDigitsOnly" DataObject.Pasting="OnLeadPaste"
                                 ToolTip="{x:Static loc:Strings.Main_CheckUpdateEveryTip}"/>
                        <TextBlock Text="{x:Static loc:Strings.Main_MinuteSuffix}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                        <CheckBox Content="{x:Static loc:Strings.Main_ZombieCheck}" IsChecked="{Binding ZombieCheckEnabled}"
                                  ToolTip="{x:Static loc:Strings.Main_ZombieCheckTip}"/>
                        <TextBox Text="{Binding ZombieFailureThreshold}" Width="28" MaxLength="2" VerticalAlignment="Center" Margin="6,0,0,0"
                                 PreviewTextInput="OnDigitsOnly" DataObject.Pasting="OnLeadPaste"
                                 ToolTip="{x:Static loc:Strings.Main_ZombieThresholdTip}"/>
                        <TextBlock Text="{x:Static loc:Strings.Main_ChecksSuffix}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,9">
                        <TextBlock Text="{x:Static loc:Strings.Main_RestCheckEvery}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Text="{Binding HealthProbeSeconds}" Width="28" MaxLength="3" VerticalAlignment="Center"
                                 PreviewTextInput="OnDigitsOnly" DataObject.Pasting="OnLeadPaste"
                                 ToolTip="{x:Static loc:Strings.Main_RestCheckEveryTip}"/>
                        <TextBlock Text="{x:Static loc:Strings.Main_SecondsSuffix}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        </StackPanel>

        <!-- Log tabs, with Server Commands docked to the far right of the tab strip -->
        <Grid Grid.Row="3">
        <TabControl Background="{x:Static local:Theme.Window}" BorderThickness="0" Padding="0,8,0,0">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource DarkTabItem}"/>
                <Style TargetType="ListBox" x:Key="LogListStyle">
                    <Setter Property="Background" Value="{x:Static local:Theme.Sunken}"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Foreground" Value="{x:Static local:Theme.LogText}"/>
                    <Setter Property="FontFamily" Value="Consolas"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
                    <Setter Property="ItemContainerStyle">
                        <Setter.Value>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="2,1"/>
                            </Style>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>
            <TabItem Header="{x:Static loc:Strings.Main_TabGeneral}">
                <ListBox x:Name="GeneralList" ItemsSource="{Binding LogGeneral}" Style="{StaticResource LogListStyle}"/>
            </TabItem>
            <TabItem Header="{x:Static loc:Strings.Main_TabServerLog}">
                <ListBox x:Name="ServerList" ItemsSource="{Binding LogServer}" Style="{StaticResource LogListStyle}"/>
            </TabItem>
            <TabItem Header="{x:Static loc:Strings.Main_TabChat}">
                <ListBox x:Name="ChatList" ItemsSource="{Binding LogChat}" Style="{StaticResource LogListStyle}"/>
            </TabItem>
            <TabItem Header="{x:Static loc:Strings.Main_TabPlayers}">
                <ListBox x:Name="PlayersList" ItemsSource="{Binding LogPlayerJoin}" Style="{StaticResource LogListStyle}"/>
            </TabItem>
            <TabItem Header="{x:Static loc:Strings.Main_TabSteamCmd}">
                <ListBox x:Name="SteamCmdList" ItemsSource="{Binding LogSteamCmd}" Style="{StaticResource LogListStyle}"/>
            </TabItem>
        </TabControl>
            <Button Content="{x:Static loc:Strings.Main_ServerCommands}" Click="OnOpenServerCommands" IsEnabled="{Binding CanUseServerCommands}"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,0,0" ToolTipService.ShowOnDisabled="True"
                    ToolTip="{x:Static loc:Strings.Main_ServerCommandsTip}"/>
        </Grid>
    </Grid>
</Window>
