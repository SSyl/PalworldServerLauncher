<Application x:Class="PalServerLauncher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PalServerLauncher">
    <Application.Resources>
        <!-- Wrap tooltips app-wide so long ones stack onto multiple lines instead of stretching off the
             screen. Hard line breaks in a tooltip string (e.g. the settings editor's "key<newline>
             description") are preserved; anything wider than MaxWidth wraps. Applies to every window and
             dialog since it lives in Application resources.
             NOTE: the ContentTemplate assumes every tooltip's content is a plain string (all of ours are).
             A tooltip whose content is an element/panel would render as its type name instead - give such a
             tooltip its own local style, or set its ToolTip to a <ToolTip> element rather than a bare string. -->
        <Style TargetType="ToolTip">
            <Setter Property="MaxWidth" Value="380"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Type ramp (sizes from Metrics; four roles). Keyed, not implicit: an implicit TextBlock style would
             recolour every stray TextBlock, so screens and dialogs opt in. -->
        <Style x:Key="Caption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{x:Static local:Theme.TextCaption}"/>
            <Setter Property="FontSize" Value="{x:Static local:Metrics.FontCaption}"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{x:Static local:Theme.Text}"/>
            <Setter Property="FontSize" Value="{x:Static local:Metrics.FontSubhead}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{x:Static local:Theme.Text}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Dark tab header, shared by the main window's log tabs and the code-built Server Settings dialog
             (which applies it via ItemContainerStyle since it has no XAML of its own). -->
        <Style x:Key="DarkTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="{x:Static local:Theme.TextMuted}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <!-- Right-side "|" divider between top tabs (the last tab's trailing one is harmless). -->
                        <Border BorderThickness="0,0,1,0" BorderBrush="{x:Static local:Theme.Divider}">
                            <Border x:Name="Bd" Background="Transparent" Padding="16,7"
                                    BorderThickness="0,0,0,2" BorderBrush="Transparent">
                                <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{x:Static local:Theme.Accent}"/>
                                <Setter TargetName="Bd" Property="Background" Value="{x:Static local:Theme.Sunken}"/>
                                <Setter Property="Foreground" Value="{x:Static local:Theme.Text}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{x:Static local:Theme.Text}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Inner sub-tab style for Server Settings > Game Settings. Every tab sits on the same near-black
             (Sunken) fill, and the ONLY selected cue is the blue (Accent) underline dash, so the strip reads as
             a flat row of tabs subordinate to the top-level DarkTabItem strip. Applied via ItemContainerStyle. -->
        <Style x:Key="DarkSubTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="{x:Static local:Theme.TextMuted}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,3,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="{x:Static local:Theme.Sunken}" Padding="14,6"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                SnapsToDevicePixels="True" UseLayoutRounding="True">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{x:Static local:Theme.Accent}"/>
                                <Setter Property="Foreground" Value="{x:Static local:Theme.Text}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{x:Static local:Theme.Text}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark button (Windows 11 style: subtle grey fill + faint border + rounded corners), applied app-wide
             so the code-built dialogs match the main window instead of the default WPF template. Colours come
             from the central Theme. MainWindow.xaml's local Button style is BasedOn this and only adds a margin.
             Hover/press are ControlTemplate triggers on the border, so they still show even when a button sets
             its own Background (the colored danger buttons). -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{x:Static local:Theme.Button}"/>
            <Setter Property="Foreground" Value="{x:Static local:Theme.Text}"/>
            <Setter Property="BorderBrush" Value="{x:Static local:Theme.ButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="{x:Static local:Metrics.ButtonPadding}"/>
            <Setter Property="MinHeight" Value="{x:Static local:Metrics.ControlHeight}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{x:Static local:Metrics.Radius}" SnapsToDevicePixels="True">
                            <Grid>
                                <!-- A translucent white overlay on hover / black on press brightens or darkens
                                     whatever the base color is, so colored buttons (danger red) get feedback too,
                                     not just the plain grey ones. -->
                                <Border x:Name="overlay" CornerRadius="{x:Static local:Metrics.Radius}" Background="White" Opacity="0"/>
                                <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="overlay" Property="Opacity" Value="0.08"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="overlay" Property="Background" Value="Black"/>
                                <Setter TargetName="overlay" Property="Opacity" Value="0.22"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark text box, app-wide. Square (the default template is already square, so no custom template),
             border turns Accent blue on hover and keyboard focus. -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{x:Static local:Theme.Field}"/>
            <Setter Property="Foreground" Value="{x:Static local:Theme.Text}"/>
            <Setter Property="BorderBrush" Value="{x:Static local:Theme.FieldBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="{x:Static local:Metrics.FieldPadding}"/>
            <Setter Property="CaretBrush" Value="{x:Static local:Theme.Caret}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{x:Static local:Theme.Accent}"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{x:Static local:Theme.Accent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Compact, centered variant for small inline numeric entry (the main window's number fields), so a
             2-3 digit value fills the box instead of drowning in prose-field padding. -->
        <Style x:Key="NumericField" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Padding" Value="3,2"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <!-- Dark checkbox, app-wide: default text colour, and dim the WHOLE control when disabled (matching the
             buttons' 0.4 opacity) so a grayed-out option clearly reads as unavailable. The default template's
             disabled cue is a light-theme grey that's nearly invisible on the dark background. -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{x:Static local:Theme.Text}"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Dark ComboBox, app-wide. Structure adapted from WPF UI's MIT-licensed ComboBox template but
             reimplemented with standard WPF parts and Theme/Metrics values, so it matches the app and stays
             dependency-free. It replaces the default LIGHT combo template that forced Foreground=Black
             workarounds. The z-order is deliberate (chevron under the toggle, editable text box on top in the
             text column only): a closed combo toggles on any click, while an editable combo still types into
             PART_EditableTextBox and toggles from the chevron. -->
        <Style x:Key="ComboToggleButton" TargetType="ToggleButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboEditableTextBox" TargetType="TextBox">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Foreground" Value="{x:Static local:Theme.Text}"/>
            <Setter Property="CaretBrush" Value="{x:Static local:Theme.Caret}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="AllowDrop" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost" Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{x:Static local:Theme.Field}"/>
            <Setter Property="Foreground" Value="{x:Static local:Theme.Text}"/>
            <Setter Property="BorderBrush" Value="{x:Static local:Theme.FieldBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="{x:Static local:Metrics.FieldPadding}"/>
            <Setter Property="MinHeight" Value="{x:Static local:Metrics.ControlHeight}"/>
            <Setter Property="FontSize" Value="{x:Static local:Metrics.FontBody}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="{x:Static local:Metrics.Radius}"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter x:Name="PART_ContentPresenter" Grid.Column="0" Margin="{TemplateBinding Padding}"
                                                      Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      HorizontalAlignment="Left" VerticalAlignment="Center" IsHitTestVisible="False"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    <TextBlock Grid.Column="1" Margin="0,0,4,0" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets"
                                               FontSize="10" Foreground="{x:Static local:Theme.TextMuted}" Text="&#xE70D;"/>
                                    <ToggleButton Grid.Column="0" Grid.ColumnSpan="2" ClickMode="Press"
                                                  Style="{StaticResource ComboToggleButton}"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                                    <TextBox x:Name="PART_EditableTextBox" Grid.Column="0" Margin="{TemplateBinding Padding}"
                                             VerticalAlignment="Center" Visibility="Hidden" Focusable="True"
                                             IsReadOnly="{TemplateBinding IsReadOnly}" Style="{StaticResource ComboEditableTextBox}"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup" Placement="Bottom" AllowsTransparency="True" Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}" PopupAnimation="Fade" VerticalOffset="2">
                                <Border Background="{x:Static local:Theme.Inset}" BorderBrush="{x:Static local:Theme.FieldBorder}"
                                        BorderThickness="1" CornerRadius="{x:Static local:Metrics.Radius}" Padding="0,3"
                                        MinWidth="{Binding ActualWidth, ElementName=border}" SnapsToDevicePixels="True">
                                    <ScrollViewer MaxHeight="{TemplateBinding MaxDropDownHeight}" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{x:Static local:Theme.Accent}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{x:Static local:Theme.Accent}"/>
                            </Trigger>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter Property="IsTabStop" Value="False"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="PART_ContentPresenter" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{x:Static local:Theme.Text}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,6,10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}"
                                Margin="3,1" CornerRadius="{x:Static local:Metrics.Radius}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{x:Static local:Theme.Button}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{x:Static local:Theme.Button}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{x:Static local:Theme.TextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark context menu + items, app-wide. The default light template reserves an icon/checkmark gutter
             that reads as a stray white box on the dark theme, so MenuItem is retemplated to a header-only leaf
             row (grey hover) with no gutter, and the menu gets the dark Sunken backdrop. Flat leaf menus only
             (no submenus/icons). Reused by any code-built ContextMenu (the RCON recent-commands list, and the
             planned system-tray menu). -->
        <Style TargetType="ContextMenu">
            <Setter Property="Foreground" Value="{x:Static local:Theme.Text}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{x:Static local:Theme.Sunken}" BorderBrush="{x:Static local:Theme.FieldBorder}"
                                BorderThickness="1" SnapsToDevicePixels="True">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                                <ItemsPresenter Margin="0,3"/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{x:Static local:Theme.Text}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="bd" Background="Transparent" Padding="12,5" SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{x:Static local:Theme.Button}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{x:Static local:Theme.TextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Squared toggle switch (a retemplated ToggleButton): a square grey track with a square thumb on the
             left when off, Accent (blue) track with the thumb on the right when on. Square (not a pill) to match
             the app, and pixel-snapped so its straight edges stay crisp (curves aliased). For compact mode. -->
        <Style x:Key="ToggleSwitch" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Width="40" Height="20" Background="Transparent" SnapsToDevicePixels="True" UseLayoutRounding="True">
                            <Border x:Name="track" CornerRadius="{x:Static local:Metrics.Radius}" Background="{x:Static local:Theme.Field}"
                                    BorderBrush="{x:Static local:Theme.FieldBorder}" BorderThickness="1"/>
                            <Border x:Name="thumb" Width="12" Height="12" Background="{x:Static local:Theme.TextMuted}"
                                    CornerRadius="{x:Static local:Metrics.Radius}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background" Value="{x:Static local:Theme.Accent}"/>
                                <Setter TargetName="track" Property="BorderBrush" Value="{x:Static local:Theme.AccentBorder}"/>
                                <Setter TargetName="thumb" Property="Background" Value="White"/>
                                <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="thumb" Property="Margin" Value="0,0,4,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
