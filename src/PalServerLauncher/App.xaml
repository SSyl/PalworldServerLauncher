<Application x:Class="PalServerLauncher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PalServerLauncher">
    <Application.Resources>
        <!-- Wrap tooltips app-wide so long ones stack onto multiple lines instead of stretching off the
             screen. Hard line breaks in a tooltip string (e.g. the settings editor's "key<newline>
             description") are preserved; anything wider than MaxWidth wraps. Applies to every window and
             dialog since it lives in Application resources.
             NOTE: the ContentTemplate assumes every tooltip's content is a plain string (all of ours are).
             A tooltip whose content is an element/panel would render as its type name instead - give such a
             tooltip its own local style, or set its ToolTip to a <ToolTip> element rather than a bare string. -->
        <Style TargetType="ToolTip">
            <Setter Property="MaxWidth" Value="380"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark tab header, shared by the main window's log tabs and the code-built Server Settings dialog
             (which applies it via ItemContainerStyle since it has no XAML of its own). -->
        <Style x:Key="DarkTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="{x:Static local:Theme.TextMuted}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <!-- Right-side "|" divider between top tabs (the last tab's trailing one is harmless). -->
                        <Border BorderThickness="0,0,1,0" BorderBrush="{x:Static local:Theme.Divider}">
                            <Border x:Name="Bd" Background="Transparent" Padding="16,7"
                                    BorderThickness="0,0,0,2" BorderBrush="Transparent">
                                <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{x:Static local:Theme.Accent}"/>
                                <Setter TargetName="Bd" Property="Background" Value="{x:Static local:Theme.Sunken}"/>
                                <Setter Property="Foreground" Value="{x:Static local:Theme.Text}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{x:Static local:Theme.Text}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Inner sub-tab style for Server Settings > Game Settings. Every tab sits on the same near-black
             (Sunken) fill, and the ONLY selected cue is the blue (Accent) underline dash, so the strip reads as
             a flat row of tabs subordinate to the top-level DarkTabItem strip. Applied via ItemContainerStyle. -->
        <Style x:Key="DarkSubTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="{x:Static local:Theme.TextMuted}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,3,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="{x:Static local:Theme.Sunken}" Padding="14,6"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                SnapsToDevicePixels="True" UseLayoutRounding="True">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{x:Static local:Theme.Accent}"/>
                                <Setter Property="Foreground" Value="{x:Static local:Theme.Text}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{x:Static local:Theme.Text}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark button (Windows 11 style: subtle grey fill + faint border + rounded corners), applied app-wide
             so the code-built dialogs match the main window instead of the default WPF template. Colours come
             from the central Theme. MainWindow.xaml's local Button style is BasedOn this and only adds a margin.
             Hover/press are ControlTemplate triggers on the border, so they still show even when a button sets
             its own Background (the colored danger buttons). -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{x:Static local:Theme.Button}"/>
            <Setter Property="Foreground" Value="{x:Static local:Theme.Text}"/>
            <Setter Property="BorderBrush" Value="{x:Static local:Theme.ButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0" SnapsToDevicePixels="True">
                            <Grid>
                                <!-- A translucent white overlay on hover / black on press brightens or darkens
                                     whatever the base color is, so colored buttons (danger red) get feedback too,
                                     not just the plain grey ones. -->
                                <Border x:Name="overlay" CornerRadius="0" Background="White" Opacity="0"/>
                                <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="overlay" Property="Opacity" Value="0.08"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="overlay" Property="Background" Value="Black"/>
                                <Setter TargetName="overlay" Property="Opacity" Value="0.22"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark text box, app-wide. Border turns the app blue (Accent) on hover and keyboard focus. -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{x:Static local:Theme.Field}"/>
            <Setter Property="Foreground" Value="{x:Static local:Theme.Text}"/>
            <Setter Property="BorderBrush" Value="{x:Static local:Theme.FieldBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,4"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{x:Static local:Theme.Accent}"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{x:Static local:Theme.Accent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Dark checkbox, app-wide: default text colour, and dim the WHOLE control when disabled (matching the
             buttons' 0.4 opacity) so a grayed-out option clearly reads as unavailable. The default template's
             disabled cue is a light-theme grey that's nearly invisible on the dark background. -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{x:Static local:Theme.Text}"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Fluent-style toggle switch (a retemplated ToggleButton): grey track with the thumb left when off,
             Accent (blue) track with the thumb right when on. Used for the compact-mode toggle. -->
        <Style x:Key="ToggleSwitch" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Width="40" Height="20" Background="Transparent">
                            <Border x:Name="track" CornerRadius="10" Background="{x:Static local:Theme.Field}"
                                    BorderBrush="{x:Static local:Theme.FieldBorder}" BorderThickness="1"/>
                            <Ellipse x:Name="thumb" Width="12" Height="12" Fill="{x:Static local:Theme.TextMuted}"
                                     HorizontalAlignment="Left" Margin="4,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background" Value="{x:Static local:Theme.Accent}"/>
                                <Setter TargetName="track" Property="BorderBrush" Value="{x:Static local:Theme.Accent}"/>
                                <Setter TargetName="thumb" Property="Fill" Value="White"/>
                                <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="thumb" Property="Margin" Value="0,0,4,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
