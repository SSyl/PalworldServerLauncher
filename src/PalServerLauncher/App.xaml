<Application x:Class="PalServerLauncher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PalServerLauncher">
    <Application.Resources>
        <!-- Wrap tooltips app-wide so long ones stack onto multiple lines instead of stretching off the
             screen. Hard line breaks in a tooltip string (e.g. the settings editor's "key<newline>
             description") are preserved; anything wider than MaxWidth wraps. Applies to every window and
             dialog since it lives in Application resources.
             NOTE: the ContentTemplate assumes every tooltip's content is a plain string (all of ours are).
             A tooltip whose content is an element/panel would render as its type name instead - give such a
             tooltip its own local style, or set its ToolTip to a <ToolTip> element rather than a bare string. -->
        <Style TargetType="ToolTip">
            <Setter Property="MaxWidth" Value="380"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
