<Application x:Class="PalServerLauncher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PalServerLauncher">
    <Application.Resources>
        <!-- Wrap tooltips app-wide so long ones stack onto multiple lines instead of stretching off the
             screen. Hard line breaks in a tooltip string (e.g. the settings editor's "key<newline>
             description") are preserved; anything wider than MaxWidth wraps. Applies to every window and
             dialog since it lives in Application resources.
             NOTE: the ContentTemplate assumes every tooltip's content is a plain string (all of ours are).
             A tooltip whose content is an element/panel would render as its type name instead - give such a
             tooltip its own local style, or set its ToolTip to a <ToolTip> element rather than a bare string. -->
        <Style TargetType="ToolTip">
            <Setter Property="MaxWidth" Value="380"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark tab header, shared by the main window's log tabs and the code-built Server Settings dialog
             (which applies it via ItemContainerStyle since it has no XAML of its own). -->
        <Style x:Key="DarkTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,3,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border BorderThickness="1,0,1,0" BorderBrush="#3A3A3A">
                            <Border x:Name="Bd" Background="Transparent" Padding="16,7"
                                    BorderThickness="0,0,0,2" BorderBrush="Transparent">
                                <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2D6CDF"/>
                                <Setter TargetName="Bd" Property="Background" Value="#141414"/>
                                <Setter Property="Foreground" Value="#F0F0F0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#F0F0F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark button, applied app-wide so the code-built dialogs match the main window instead of falling
             back to the default WPF template (whose hover/press paints an unreadable light-blue over the text).
             MainWindow.xaml has its own local Button style that overrides this for the main window. Hover/press
             are ControlTemplate triggers on the border, so they still show even when a dialog button sets its
             own Background. -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" SnapsToDevicePixels="True">
                            <Grid>
                                <!-- A translucent white overlay on hover / black on press brightens or darkens
                                     whatever the base color is, so colored buttons (amber, red) get feedback too,
                                     not just the plain gray ones. -->
                                <Border x:Name="overlay" CornerRadius="4" Background="White" Opacity="0"/>
                                <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="overlay" Property="Opacity" Value="0.12"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="overlay" Property="Background" Value="Black"/>
                                <Setter TargetName="overlay" Property="Opacity" Value="0.22"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
