<Window x:Class="PalServerLauncher.Views.RestartTimesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Restart Times"
        Background="#2F2F2F" Foreground="#E0E0E0"
        FontFamily="Segoe UI" FontSize="13"
        SizeToContent="WidthAndHeight" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" MinWidth="300">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#555555"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <StackPanel Margin="16" MinWidth="240">
        <TextBlock x:Name="HeaderText" Text="Restart times" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Every" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox x:Name="EveryBox" Width="72" IsEditable="True"
                      ToolTip="Fill the whole day at this interval, stepping from midnight. Pick a preset or type a decimal like 2.5. Replaces the times below."/>
            <Button Content="Apply" Click="ApplyEvery" Margin="8,0,0,0" MinWidth="52"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <ComboBox x:Name="HourBox" Width="52"/>
            <TextBlock Text=":" VerticalAlignment="Center" Margin="4,0"/>
            <ComboBox x:Name="MinuteBox" Width="52" IsEditable="True" PreviewTextInput="MinuteDigitsOnly"
                      ToolTip="Any minute 0-59 - pick a preset or type it"/>
            <ComboBox x:Name="AmPmBox" Width="52" Margin="6,0,0,0"/>
            <Button Content="Add" Click="AddTime" Margin="10,0,0,0" MinWidth="52"/>
        </StackPanel>

        <ListBox x:Name="TimesList" Height="170" Background="#141414" Foreground="#E0E0E0"
                 BorderBrush="#3A3A3A" BorderThickness="1">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding" Value="4,2"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Right" Content="✕" Click="RemoveTime" Tag="{Binding}"
                                Width="24" Padding="0,2" Background="#7a3a3a"/>
                        <TextBlock Text="{Binding Display}" VerticalAlignment="Center" FontFamily="Consolas"/>
                    </DockPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Button Content="Done" Click="Done" HorizontalAlignment="Right" Margin="0,12,0,0" MinWidth="80"/>
    </StackPanel>
</Window>
