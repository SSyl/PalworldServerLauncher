<Window x:Class="PalServerLauncher.Views.RestartTimesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PalServerLauncher"
        xmlns:loc="clr-namespace:PalServerLauncher.Localization;assembly=PalServerLauncher.Localization"
        Title="{x:Static loc:Strings.Times_RestartTitle}"
        Background="{x:Static local:Theme.Window}" Foreground="{x:Static local:Theme.Text}"
        FontFamily="Segoe UI" FontSize="{x:Static local:Metrics.FontBody}"
        SizeToContent="WidthAndHeight" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" MinWidth="300">
    <StackPanel Margin="16" MinWidth="240">
        <TextBlock x:Name="HeaderText" Text="{x:Static loc:Strings.Times_RestartHeader}" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="{x:Static loc:Strings.Times_Every}" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox x:Name="EveryBox" Width="72" VerticalAlignment="Center" IsEditable="True"
                      ToolTip="{x:Static loc:Strings.Times_EveryTip}"/>
            <Button Content="{x:Static loc:Strings.Times_Apply}" Click="ApplyEvery" Margin="8,0,0,0" MinWidth="52"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <ComboBox x:Name="HourBox" Width="56" VerticalAlignment="Center"/>
            <TextBlock Text=":" VerticalAlignment="Center" Margin="4,0"/>
            <ComboBox x:Name="MinuteBox" Width="56" VerticalAlignment="Center" IsEditable="True" PreviewTextInput="MinuteDigitsOnly"
                      ToolTip="{x:Static loc:Strings.Times_MinuteTip}"/>
            <ComboBox x:Name="AmPmBox" Width="56" VerticalAlignment="Center" Margin="6,0,0,0"/>
            <Button Content="{x:Static loc:Strings.Times_Add}" Click="AddTime" Margin="8,0,0,0" MinWidth="52"/>
        </StackPanel>

        <ListBox x:Name="TimesList" Height="170" Background="{x:Static local:Theme.Sunken}" Foreground="{x:Static local:Theme.Text}"
                 BorderBrush="{x:Static local:Theme.Divider}" BorderThickness="1">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding" Value="4,2"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <DockPanel LastChildFill="True">
                        <!-- Shared delete-button coloring (gray box, red on hover): App.xaml CloseButtonStyle. -->
                        <Button DockPanel.Dock="Right" Content="&#xE711;" Click="RemoveTime" Tag="{Binding}"
                                Style="{StaticResource CloseButtonStyle}"/>
                        <TextBlock Text="{Binding Display}" VerticalAlignment="Center" FontFamily="Consolas"/>
                    </DockPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Button Content="{x:Static loc:Strings.Times_Done}" Click="Done" HorizontalAlignment="Right" Margin="0,12,0,0" MinWidth="80"/>
    </StackPanel>
</Window>
